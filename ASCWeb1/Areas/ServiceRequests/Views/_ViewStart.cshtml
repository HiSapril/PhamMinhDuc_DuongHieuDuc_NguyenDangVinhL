@using ASC.Utilities
@{
    var currentUser = User.GetCurrentUserDetails();
    // User role (khách hàng) dùng layout đơn giản, Admin/Engineer dùng layout đầy đủ
    Layout = currentUser.Roles.Contains("User") && !currentUser.Roles.Contains("Admin") && !currentUser.Roles.Contains("Engineer") 
        ? "_UserLayout" 
        : "_SecureLayout";
}
