@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Register";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col s12 m8 offset-m2 l6 offset-l3">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="card-panel red lighten-4 red-text text-darken-4">
                    <i class="material-icons left">error</i>
                    @Model.ErrorMessage
                </div>
            }
            
            @if (!string.IsNullOrEmpty(Model.ProviderDisplayName))
            {
                <div class="card">
                    <div class="card-content">
                        <span class="card-title center-align">
                            <i class="material-icons medium teal-text">account_circle</i>
                            <br/>
                            Complete Registration
                        </span>
                        
                        <p class="center-align grey-text text-darken-1" style="margin-bottom: 20px;">
                            You've successfully authenticated with <strong>@Model.ProviderDisplayName</strong>.
                            <br/>Please confirm your information to complete registration.
                        </p>
                        
                        <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <div asp-validation-summary="ModelOnly" class="red-text"></div>
                            
                            <div class="row" style="margin-bottom: 20px;">
                                <div class="input-field col s12">
                                    <i class="material-icons prefix">email</i>
                                    <input asp-for="Input.Email" type="email" id="email" readonly class="validate">
                                    <label for="email" class="active">Email Address</label>
                                    <span asp-validation-for="Input.Email" class="red-text"></span>
                                </div>
                            </div>
                            
                            <div class="row center-align" style="margin-top: 30px;">
                                <button class="btn waves-effect waves-light teal" type="submit" style="width: 100%; max-width: 300px;">
                                    Complete Registration
                                    <i class="material-icons right">check</i>
                                </button>
                            </div>
                            
                            <div class="row center-align" style="margin-top: 15px;">
                                <a href="@Url.Page("./Login")" class="grey-text">
                                    <i class="material-icons tiny">arrow_back</i>
                                    Back to Login
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-content center-align">
                        <div class="preloader-wrapper big active">
                            <div class="spinner-layer spinner-teal-only">
                                <div class="circle-clipper left">
                                    <div class="circle"></div>
                                </div>
                                <div class="gap-patch">
                                    <div class="circle"></div>
                                </div>
                                <div class="circle-clipper right">
                                    <div class="circle"></div>
                                </div>
                            </div>
                        </div>
                        <p class="flow-text" style="margin-top: 20px;">Processing your login...</p>
                        <p class="grey-text">Please wait a moment</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
