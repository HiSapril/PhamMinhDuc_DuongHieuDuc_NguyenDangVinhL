@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Reset password confirmation";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 40px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-sm-8 col-12">
                <div class="card shadow-sm text-center">
                    <div class="card-body p-4">
                        <i class="material-icons large green-text" style="font-size: 80px;">check_circle</i>
                        <h4 class="card-title mt-2">Password Reset Successful</h4>
                        <p class="text-muted" style="margin: 20px 0;">
                            Your password has been reset successfully. You can now login with your new password.
                        </p>
                        <a href="/Identity/Account/Login" class="btn btn-lg btn-primary w-100">
                            Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
