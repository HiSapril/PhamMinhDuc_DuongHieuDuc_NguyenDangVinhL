@page
@model LogoutModel
@{
    ViewData["Title"] = "Logged Out";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div style="min-height: 60vh; display: flex; align-items: center; justify-content: center;">
<div class="container">
    <div class="row">
        <div class="col s12 m6 offset-m3 l4 offset-10">
            <div class="card">
                <div class="card-content center-align">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <i class="material-icons large teal-text" style="font-size: 80px;">exit_to_app</i>
                        <h4 class="card-title">Logout</h4>
                        <p class="grey-text" style="margin: 20px 0;">Are you sure you want to logout?</p>
                        
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                            <button type="submit" class="btn waves-effect waves-light teal" style="margin-top: 20px;">
                                <i class="material-icons left">exit_to_app</i>
                                Confirm Logout
                            </button>
                        </form>
                        
                        <div style="margin-top: 20px;">
                            <a href="javascript:history.back()" class="grey-text">
                                <i class="material-icons tiny">arrow_back</i>
                                Go Back
                            </a>
                        </div>
                    }
                    else
                    {
                        <i class="material-icons large green-text" style="font-size: 80px;">check_circle</i>
                        <h4 class="card-title">Logged Out Successfully</h4>
                        <p class="grey-text" style="margin: 20px 0;">You have successfully logged out of the application.</p>
                        
                        <a href="/Identity/Account/Login" class="btn waves-effect waves-light teal" style="margin-top: 20px;">
                            <i class="material-icons left">login</i>
                            Login Again
                        </a>
                        
                        <div style="margin-top: 20px;">
                            <a href="/" class="grey-text">
                                <i class="material-icons tiny">home</i>
                                Go to Home
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
</div>