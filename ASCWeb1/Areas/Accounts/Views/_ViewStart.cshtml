@using ASC.Utilities
@{
    var currentUser = User.GetCurrentUserDetails();
    // User role (khách hàng) dùng layout đơn giản, Admin/Engineer dùng layout đầy đủ
    Layout = currentUser?.Roles.Contains("User") == true && currentUser?.Roles.Contains("Admin") != true && currentUser?.Roles.Contains("Engineer") != true 
        ? "_UserLayout" 
        : "_SecureLayout";
}
