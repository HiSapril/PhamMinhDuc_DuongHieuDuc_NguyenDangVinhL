@using Microsoft.AspNetCore.Http
@using ASC.Utilities
@using ASCWeb1.Data
@inject IHttpContextAccessor UserHttpContext
@inject INavigationCacheOperations navigationCache

@{
    Layout = "_MasterLayout";
    var currentUser = UserHttpContext.HttpContext.User.GetCurrentUserDetails();
}

<header class="secureLayout">
    <nav class="top-nav blue-grey lighten-1">
        <div class="nav-wrapper row valign-wrapper">
            <div class="col s12 valign-wrapper">
                <a href="#" data-target="nav-mobile" class="sidenav-trigger"><i class="material-icons">menu</i></a>
                <h5><a class="page-title">Automobile Service Center</a></h5>
            </div>
        </div>
    </nav>

    <ul id="nav-mobile" class="sidenav sidenav-fixed">
        <li>
            <div class="user-view" style="padding: 32px 32px 16px;">
                <div class="background blue-grey lighten-1"></div>
                <a href="/Accounts/Account/Profile" style="margin-bottom: 12px; display: block;">
                    @{
                        var avatarUrl = currentUser?.ProfilePictureUrl;
                        var userName = currentUser?.Name ?? currentUser?.Email ?? "User";
                        var defaultAvatar = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(userName)}&size=64&background=607d8b&color=fff";
                    }
                    <img class="circle" 
                         id="userAvatar"
                         src="@(string.IsNullOrEmpty(avatarUrl) ? defaultAvatar : avatarUrl)" 
                         alt="User Avatar" 
                         onerror="this.onerror=null; this.src='@defaultAvatar';" 
                         style="width: 64px; height: 64px; object-fit: cover;">
                </a>
                <a href="/Accounts/Account/Profile" style="margin-top: 8px; display: block;">
                    <span class="white-text name" style="font-size: 16px; font-weight: 500;">@currentUser.Name</span>
                </a>
                <a href="/Accounts/Account/Profile" style="margin-top: 4px; display: block;">
                    <span class="white-text email" style="font-size: 14px; opacity: 0.9;">@currentUser.Email</span>
                </a>
            </div>
        </li>
        <li><div class="divider"></div></li>
        @await Component.InvokeAsync("ASCWeb1.Navigation.LeftNavigation", await navigationCache.GetNavigationCacheAsync())
        <li><div class="divider"></div></li>
        <li>
            <a href="#" id="ancrLogoutSidebar" style="padding: 0 32px;">
                <i class="material-icons">exit_to_app</i>
                Logout
            </a>
        </li>
    </ul>
    
    <form id="logout_form" method="post" asp-area="Identity" asp-page="/Account/Logout"></form>
    <form id="resetPassword_form" method="post" asp-area="" asp-controller="Account" asp-action="InitiateResetPassword"></form>
</header>

<main class="secureLayout">
    <div class="row margin-bottom-0px">
        <div class="col s12">
            @RenderBody()
        </div>
    </div>
</main>

<footer class="page-footer blue-grey lighten-1 secureLayout" style="@(ViewData["HideFooter"] != null && (bool)ViewData["HideFooter"] ? "display:none;" : "")">
    <div class="container">
        <div class="row">
            <div class="col l6 s12">
                <h5 class="white-text">About Us</h5>
                <p class="grey-text text-lighten-4">
                    Automobile Service Center is certified Company to perform car services. Our
                    Workshop operations started in the month of October, 2010.
                    We primarily focus on providing better services to our customers, and as a
                    result of the hard work we were awarded as the "Best Service" for the year
                    2008 and that too within a short period of time.
                </p>
            </div>
            <div class="col l3 s12">
                <h5 class="white-text">Additional Services</h5>
                <ul>
                    <li><a class="white-text" href="#!">Services</a></li>
                    <li><a class="white-text" href="#!">Finance</a></li>
                    <li><a class="white-text" href="#!">Used Cars</a></li>
                    <li><a class="white-text" href="#!">Insurance</a></li>
                    <li><a class="white-text" href="#!">Driving School</a></li>
                </ul>
            </div>
            <div class="col l3 s12">
                <h5 class="white-text">Connect</h5>
                <ul>
                    <li><a class="white-text" href="#!">Facebook</a></li>
                    <li><a class="white-text" href="#!">LinkedIn</a></li>
                    <li><a class="white-text" href="#!">Twitter</a></li>
                    <li><a class="white-text" href="#!">Youtube</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="footer-copyright row margin-bottom-0px">
        <div class="col s12">
            Powered by <a class="brown-text text-lighten-3" href="http://materializecss.com">Materialize</a>
        </div>
    </div>
</footer>

@section Scripts {
    @RenderSection("Scripts", required: false)
    <script type="text/javascript">
        $(function () {
            // Logout handlers
            $('#ancrLogoutSidebar').click(function (e) {
                e.preventDefault();
                $('#logout_form').submit();
            });
            
            $('#ancrResetPassword').click(function () {
                $('#resetPassword_form').submit();
            });
        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.collapsible').collapsible();
        });
    </script>
}