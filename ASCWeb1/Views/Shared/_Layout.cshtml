@using Microsoft.Extensions.Options
@inject IOptions<ASCWeb1.Configuration.ApplicationSettings> _configurationSettings

@{
    Layout = "_MasterLayout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ASCWeb1</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ASCWeb1.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        Layout = "_MasterLayout";
    }

    <header>
        <nav class="white" role="navigation">
            <div class="nav-wrapper container">
                <a id="logo-container" href="/" class="brand-logo">
                    <img class="responsive-img" src="~/images/logo.jpg" alt="Logo" style="height: 64px;" />
                </a>

                <ul class="right hide-on-med-and-down">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li>
                            <a class='dropdown-trigger' href='#' data-target='user-dropdown-public'>
                                @{
                                    var userName = User.Identity.Name ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "User";
                                }
                                <i class="material-icons left">account_circle</i>
                                @userName
                                <i class="material-icons right">arrow_drop_down</i>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li><a href="/Identity/Account/Login"><i class="material-icons left">login</i>Login</a></li>
                    }
                    <li><a href="#contact">Contact</a></li>
                </ul>

                <!-- Dropdown Structure -->
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <ul id='user-dropdown-public' class='dropdown-content'>
                        <li>
                            <a href="/ServiceRequests/Dashboard/Dashboard">
                                <i class="material-icons">dashboard</i>
                                Dashboard
                            </a>
                        </li>
                        <li>
                            <a href="/Accounts/Account/Profile">
                                <i class="material-icons">account_circle</i>
                                Profile
                            </a>
                        </li>
                        <li class="divider"></li>
                        <li>
                            <a href="#" id="ancrLogoutPublic">
                                <i class="material-icons">exit_to_app</i>
                                Logout
                            </a>
                        </li>
                    </ul>
                    <form id="logout_form_public" method="post" asp-area="Identity" asp-page="/Account/Logout"></form>
                }

                <ul id="nav-mobile" class="sidenav">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li>
                            <a href="/ServiceRequests/Dashboard/Dashboard">
                                <i class="material-icons">dashboard</i>
                                Dashboard
                            </a>
                        </li>
                        <li>
                            <a href="/Accounts/Account/Profile">
                                <i class="material-icons">account_circle</i>
                                Profile
                            </a>
                        </li>
                        <li class="divider"></li>
                        <li>
                            <a href="#" id="ancrLogoutMobile">
                                <i class="material-icons">exit_to_app</i>
                                Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <li><a href="/Identity/Account/Login">Login</a></li>
                    }
                    <li><a href="#contact">Contact</a></li>
                </ul>

                <a href="#" data-target="nav-mobile" class="sidenav-trigger">
                    <i class="material-icons">menu</i>
                </a>
            </div>
        </nav>

        <div id="index-banner" class="parallax-container">
            <div class="section no-pad-bot">
                <div class="container">
                    <br><br>
                    <h1 class="header center teal-text text-lighten-2">Automobile Service Center</h1>
                    <div class="row center">
                        <h5 class="header col s12 light">Where Quality meets Safety</h5>
                    </div>
                    <div class="row center">
                        <a href="http://materializecss.com/getting-started.html" id="downloadbutton" class="btn-large waves-effect waves-light teal lighten-1">
                            Get Started
                        </a>
                    </div>
                    <br><br>
                </div>
            </div>
            <div class="parallax">
                <img src="~/images/background1.jpg" alt="Unsplashed background img 1">
            </div>
        </div>
    </header>

    <main>
        <div class="row margin-bottom-0px">
            <div class="col s12 padding-0px">
                @RenderBody()
            </div>
        </div>
    </main>
    

    <footer class="page-footer teal">
        <div class="container">
            <div class="row">
                <div class="col l6 s12">
                    <h5 class="white-text">About Us</h5>
                    <p class="grey-text text-lighten-4">
                        Automobile Service Center is certified to perform car services. Our
                        workshop operations started in October 2010.
                        We primarily focus on providing better services to our customers, and as
                        a result of the hard work, we were awarded "Best Service" for 2008.
                    </p>
                </div>
                <div class="col l3 s12">
                    <h5 class="white-text">Additional Services</h5>
                    <ul>
                        <li><a class="white-text" href="#!">Services</a></li>
                        <li><a class="white-text" href="#!">Finance</a></li>
                        <li><a class="white-text" href="#!">Used Cars</a></li>
                        <li><a class="white-text" href="#!">Insurance</a></li>
                        <li><a class="white-text" href="#!">Driving School</a></li>
                    </ul>
                </div>
                <div class="col l3 s12">
                    <h5 class="white-text">Connect</h5>
                    <ul>
                        <li><a class="white-text" href="#!">Facebook</a></li>
                        <li><a class="white-text" href="#!">LinkedIn</a></li>
                        <li><a class="white-text" href="#!">Twitter</a></li>
                        <li><a class="white-text" href="#!">Youtube</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-copyright">
            <div class="container">
                Powered by <a class="brown-text text-lighten-3" href="http://materializecss.com">Materialize</a>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/materialize.min.js"></script>
    <script src="~/js/init.js"></script>
    <script>
        $(document).ready(function(){
            $('.sidenav').sidenav();
            $('.parallax').parallax();
            $('.dropdown-trigger').dropdown({
                coverTrigger: false,
                constrainWidth: false,
                alignment: 'right'
            });
            
            $('#ancrLogoutPublic, #ancrLogoutMobile').click(function (e) {
                e.preventDefault();
                $('#logout_form_public').submit();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
