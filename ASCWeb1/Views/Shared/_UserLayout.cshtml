@using Microsoft.AspNetCore.Http
@using ASC.Utilities
@inject IHttpContextAccessor UserHttpContext

@{
    Layout = "_MasterLayout";
    var currentUser = UserHttpContext.HttpContext.User.GetCurrentUserDetails();
}

<header>
    <nav class="teal lighten-1" role="navigation">
        <div class="nav-wrapper container">
            <a id="logo-container" href="/" class="brand-logo">
                <img class="responsive-img" src="~/images/logo.jpg" alt="Logo" style="height: 64px;" />
            </a>

            <ul class="right hide-on-med-and-down">
                <li>
                    <a href="#" id="ancrLogoutHeader" class="white-text">
                        @{
                            var avatarUrl = currentUser?.ProfilePictureUrl;
                            var userName = currentUser?.Name ?? currentUser?.Email ?? "User";
                            var defaultAvatar = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(userName)}&size=32&background=fff&color=009688";
                        }
                        <img class="circle" 
                             src="@(string.IsNullOrEmpty(avatarUrl) ? defaultAvatar : avatarUrl)" 
                             alt="User Avatar" 
                             onerror="this.onerror=null; this.src='@defaultAvatar';" 
                             style="width: 32px; height: 32px; object-fit: cover; vertical-align: middle; margin-right: 8px;">
                        <span>@userName</span>
                        <i class="material-icons right">exit_to_app</i>
                    </a>
                </li>
            </ul>

            <ul id="nav-mobile" class="sidenav">
                <li>
                    <div class="user-view" style="padding: 32px 32px 16px;">
                        <div class="background teal lighten-1"></div>
                        <a href="#" style="margin-bottom: 12px; display: block;">
                            @{
                                var sidebarAvatarUrl = currentUser?.ProfilePictureUrl;
                                var sidebarUserName = currentUser?.Name ?? currentUser?.Email ?? "User";
                                var sidebarDefaultAvatar = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(sidebarUserName)}&size=64&background=009688&color=fff";
                            }
                            <img class="circle" 
                                 src="@(string.IsNullOrEmpty(sidebarAvatarUrl) ? sidebarDefaultAvatar : sidebarAvatarUrl)" 
                                 alt="User Avatar" 
                                 onerror="this.onerror=null; this.src='@sidebarDefaultAvatar';" 
                                 style="width: 64px; height: 64px; object-fit: cover;">
                        </a>
                        <a href="#" style="margin-top: 8px; display: block;">
                            <span class="white-text name" style="font-size: 16px; font-weight: 500;">@currentUser.Name</span>
                        </a>
                        <a href="#" style="margin-top: 4px; display: block;">
                            <span class="white-text email" style="font-size: 14px; opacity: 0.9;">@currentUser.Email</span>
                        </a>
                    </div>
                </li>
                <li><div class="divider"></div></li>
                <li>
                    <a href="#" id="ancrLogoutMobile" style="padding: 0 32px;">
                        <i class="material-icons">exit_to_app</i>
                        Logout
                    </a>
                </li>
            </ul>

            <a href="#" data-target="nav-mobile" class="sidenav-trigger white-text">
                <i class="material-icons">menu</i>
            </a>
        </div>
    </nav>
    
    <form id="logout_form" method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/"></form>
</header>

<main style="min-height: calc(100vh - 200px); padding: 20px 0;">
    <div class="container">
        <div class="row">
            <div class="col s12">
                @RenderBody()
            </div>
        </div>
    </div>
</main>

<footer class="page-footer teal lighten-1">
    <div class="container">
        <div class="row">
            <div class="col l6 s12">
                <h5 class="white-text">About Us</h5>
                <p class="grey-text text-lighten-4">
                    Automobile Service Center is certified Company to perform car services. Our
                    Workshop operations started in the month of October, 2010.
                    We primarily focus on providing better services to our customers, and as a
                    result of the hard work we were awarded as the "Best Service" for the year
                    2008 and that too within a short period of time.
                </p>
            </div>
            <div class="col l3 s12">
                <h5 class="white-text">Additional Services</h5>
                <ul>
                    <li><a class="white-text" href="#!">Services</a></li>
                    <li><a class="white-text" href="#!">Finance</a></li>
                    <li><a class="white-text" href="#!">Used Cars</a></li>
                    <li><a class="white-text" href="#!">Insurance</a></li>
                    <li><a class="white-text" href="#!">Driving School</a></li>
                </ul>
            </div>
            <div class="col l3 s12">
                <h5 class="white-text">Connect</h5>
                <ul>
                    <li><a class="white-text" href="#!">Facebook</a></li>
                    <li><a class="white-text" href="#!">LinkedIn</a></li>
                    <li><a class="white-text" href="#!">Twitter</a></li>
                    <li><a class="white-text" href="#!">Youtube</a></li>
                </ul>
            </div>
        </div>
    </div>
    <div class="footer-copyright">
        <div class="container">
            Powered by <a class="brown-text text-lighten-3" href="http://materializecss.com">Materialize</a>
        </div>
    </div>
</footer>

@section Scripts {
    @RenderSection("Scripts", required: false)
    <script type="text/javascript">
        $(function () {
            // Initialize sidenav
            $('.sidenav').sidenav();
            
            // Logout handlers - submit form immediately
            $('#ancrLogoutHeader, #ancrLogoutMobile').click(function (e) {
                e.preventDefault();
                $('#logout_form').submit();
            });
        });
    </script>
}
