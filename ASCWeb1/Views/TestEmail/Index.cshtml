@{
    ViewData["Title"] = "Test Email";
    Layout = "_MasterLayout";
}

<div class="container" style="margin-top: 50px;">
    <div class="row">
        <div class="col s12 m8 offset-m2">
            <div class="card">
                <div class="card-content">
                    <span class="card-title">Test Gửi Email</span>
                    
                    <div class="card-panel blue-grey lighten-5">
                        <h6>Cấu hình SMTP hiện tại:</h6>
                        <p><strong>Server:</strong> @ViewBag.SMTPServer</p>
                        <p><strong>Port:</strong> @ViewBag.SMTPPort</p>
                        <p><strong>Account:</strong> @ViewBag.SMTPAccount</p>
                        <p><strong>Password Length:</strong> @ViewBag.PasswordLength ký tự</p>
                    </div>

                    <div class="row">
                        <div class="input-field col s12">
                            <input type="email" id="testEmail" placeholder="waterfallnee@gmail.com" value="waterfallnee@gmail.com" />
                            <label for="testEmail" class="active">Nhập email để test</label>
                        </div>
                    </div>

                    <button class="btn blue-grey waves-effect waves-light" onclick="sendTestEmail()">
                        Gửi Email Test
                        <i class="material-icons right">send</i>
                    </button>

                    <div id="result" style="margin-top: 20px;"></div>
                </div>
            </div>

            <div class="card">
                <div class="card-content">
                    <span class="card-title">Hướng dẫn</span>
                    <ol>
                        <li>Đảm bảo đã tạo App Password cho Gmail <code>@ViewBag.SMTPAccount</code></li>
                        <li>App Password phải có 16 ký tự (không có khoảng trắng)</li>
                        <li>Nhập email và click "Gửi Email Test"</li>
                        <li>Kiểm tra console log trong Visual Studio để xem chi tiết</li>
                        <li>Kiểm tra hộp thư (cả spam) của email nhận</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function sendTestEmail() {
            var email = document.getElementById('testEmail').value;
            var resultDiv = document.getElementById('result');
            
            if (!email) {
                M.toast({html: 'Vui lòng nhập email', classes: 'red'});
                return;
            }

            resultDiv.innerHTML = '<div class="progress"><div class="indeterminate"></div></div><p>Đang gửi email...</p>';

            fetch('/TestEmail/Send', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'email=' + encodeURIComponent(email)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    resultDiv.innerHTML = '<div class="card-panel green lighten-4"><span class="green-text text-darken-4"><i class="material-icons left">check_circle</i>' + data.message + '</span></div>';
                    M.toast({html: 'Email đã gửi!', classes: 'green'});
                } else {
                    resultDiv.innerHTML = '<div class="card-panel red lighten-4"><span class="red-text text-darken-4"><i class="material-icons left">error</i>' + data.message + '</span></div>';
                    M.toast({html: 'Lỗi gửi email', classes: 'red'});
                }
            })
            .catch(error => {
                resultDiv.innerHTML = '<div class="card-panel red lighten-4"><span class="red-text text-darken-4">Lỗi: ' + error + '</span></div>';
                M.toast({html: 'Lỗi kết nối', classes: 'red'});
            });
        }
    </script>
}
